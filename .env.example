# ============================================================
# OBLIGATORIAS para que funcione el análisis:
#   1. GLACIER_API_KEY
#   2. HUGGINGFACE_API_KEY o OPENAI_API_KEY (al menos una)
# ============================================================

# Avalanche Glacier API (obtén tu key en https://app.avacloud.io/)
GLACIER_API_KEY=your_glacier_api_key_here

# Hugging Face API (principal para pruebas gratis)
# Token: https://huggingface.co/settings/tokens (tipo "Read" suele bastar)
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here
# Opcional. Formato: modelo:proveedor para https://router.huggingface.co/v1/chat/completions
# Si HF falla (403/404/model not found), comenta esta línea: el backend probará modelos de respaldo.
# HF_MODEL=meta-llama/Llama-3.3-70B-Instruct:fireworks-ai

# OpenAI API (fallback opcional)
OPENAI_API_KEY=sk-your_openai_key_here

# GenLayer (opcional - si se configuran, se usa el Intelligent Contract)
GENLAYER_CONTRACT_ADDRESS=
GENLAYER_PRIVATE_KEY=

# Puerto del servidor
PORT=3001

# RPC URL y API Keys para Multi-Chain (Ethereum, Polygon, BSC)
# Si no las pones, el backend usará nodos públicos y llamadas limitadas en Etherscan.
ETH_RPC_URL=https://eth.llamarpc.com
POLYGON_RPC_URL=https://polygon-rpc.com
BSC_RPC_URL=https://bsc-dataseed.binance.org

# API Keys para transacciones (Etherscan, Polygonscan, BscScan)
ETH_API_KEY=your_etherscan_key_here
POLYGON_API_KEY=your_polygonscan_key_here
BSC_API_KEY=your_bscscan_key_here

# Precios USD para visualización
AVAX_USD_PRICE=35
ETH_USD_PRICE=3500
POL_USD_PRICE=0.70
BNB_USD_PRICE=600

# --- x402 (pago USDC por análisis; opcional) ---
# Si es true, GET /api/analyze/:address exige pago vía x402 (402 + facilitator).
X402_ENABLED=false
# Dirección EVM que recibe USDC (tu wallet comerciante).
X402_PAY_TO=
# Monto en unidades mínimas USDC (6 decimales). 10000 = 0.01 USDC.
X402_AMOUNT_USDC=10000
# Red de cobro: fuji (testnet) o mainnet (Avalanche C-Chain).
X402_NETWORK=fuji
# Facilitator HTTP (por defecto PayAI; compatible Avalanche).
# X402_FACILITATOR_URL=https://facilitator.payai.network
# Opcional: claves PayAI para producción / límites mayores
# PAYAI_API_KEY_ID=
# PAYAI_API_KEY_SECRET=
