# Avalanche Glacier API (obtén tu key en https://app.avacloud.io/)
GLACIER_API_KEY=your_glacier_api_key_here

# Hugging Face API (principal para pruebas gratis)
HUGGINGFACE_API_KEY=hf_your_huggingface_token_here
# Para router.huggingface.co usa formato model:provider (ejemplo estable)
HF_MODEL=meta-llama/Llama-3.3-70B-Instruct:fireworks-ai

# OpenAI API (fallback opcional)
OPENAI_API_KEY=sk-your_openai_key_here

# GenLayer (opcional - si se configuran, se usa el Intelligent Contract)
GENLAYER_CONTRACT_ADDRESS=
GENLAYER_PRIVATE_KEY=

# Puerto del servidor
PORT=3001

# Precio estimado de AVAX en USD (para calcular gas_usd)
AVAX_USD_PRICE=35
